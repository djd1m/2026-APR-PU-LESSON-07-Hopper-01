# ─── Database ────────────────────────────────────────────────
DB_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://hopperru:${DB_PASSWORD}@localhost:5432/hopperru

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── ClickHouse ──────────────────────────────────────────────
CLICKHOUSE_PASSWORD=change_me
CLICKHOUSE_URL=http://localhost:8123

# ─── YooKassa (Payments) ────────────────────────────────────
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET=your_secret_key

# ─── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change_me_to_random_32_chars

# ─── Insurance Partner ───────────────────────────────────────
INSURANCE_PARTNER_API_URL=https://api.insurance-partner.ru
INSURANCE_PARTNER_API_KEY=your_api_key

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
WEB_PORT=3001
ML_PORT=8000
