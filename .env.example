# ═══════════════════════════════════════════════════════════════
# HopperRU — Environment Variables
# Copy to .env and fill in the values
# ═══════════════════════════════════════════════════════════════

# ─── Ports (unique range to avoid VPS conflicts) ─────────────
API_PORT=9100           # NestJS API → http://localhost:9100
WEB_PORT=9101           # Next.js Web → http://localhost:9101
ML_PORT=9102            # FastAPI ML  → http://localhost:9102
PG_PORT=9103            # PostgreSQL  → localhost:9103 (localhost only)
REDIS_PORT=9104         # Redis       → localhost:9104 (localhost only)
CH_HTTP_PORT=9105       # ClickHouse  → localhost:9105 (localhost only)
CH_NATIVE_PORT=9106     # ClickHouse  → localhost:9106 (localhost only)

# ─── Database ────────────────────────────────────────────────
DB_PASSWORD=hopperru_dev_2026       # CHANGE in production!

# ─── ClickHouse ──────────────────────────────────────────────
CLICKHOUSE_PASSWORD=hopperru_ch_2026

# ─── JWT (generate: openssl rand -hex 32) ────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── YooKassa (Payments) ────────────────────────────────────
# Get from: https://yookassa.ru/my/shop-settings
# For testing: use test shop ID from YooKassa sandbox
YOOKASSA_SHOP_ID=test_shop_id
YOOKASSA_SECRET=test_secret_key

# ─── Web Push (VAPID keys) ──────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@hopperru.ru

# ─── Travelpayouts (real flight data) ────────────────────────
# Register at: https://www.travelpayouts.com/programs/100/tools/api
# Without this, search returns mock flight data
TRAVELPAYOUTS_TOKEN=

# ─── SMSC.ru (real SMS sending) ──────────────────────────────
# Register at: https://smsc.ru/reg/
# Without these, SMS codes are logged to console (mock mode)
SMSC_LOGIN=
SMSC_PASSWORD=

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development

# ─── Booking Provider ────────────────────────────────────────
# "mock" (default) = simulated booking, no real GDS
# "nemo" = real booking via Nemo.travel (requires contract)
BOOKING_PROVIDER=mock

# ─── Nemo.travel (real GDS booking) ─────────────────────────
# Contract required: https://www.nemo.travel/
# Cost: ~$500/mo + $0.25/ticket
# Apply: helpdesk.nemo.travel
NEMO_API_URL=
NEMO_API_KEY=
NEMO_AGENCY_ID=
